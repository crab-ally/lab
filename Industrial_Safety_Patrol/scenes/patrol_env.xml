<mujoco model="turtlebot_indoor_test">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
    <option integrator="RK4" timestep="0.01" gravity="0 0 -9.81"/>

    <worldbody>
        <!-- 1. 실내 바닥 및 조명 -->
        <geom name="floor" type="plane" size="5 5 0.1" rgba="0.8 0.8 0.8 1"/>
        <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 5" dir="0 0 -1"/>

        <!-- 2. 실내 벽면 (Indoor Boundary) [1] -->
        <geom name="wall_n" type="box" size="5 0.05 0.5" pos="0 5 0.5" rgba="0.5 0.5 0.5 1"/>
        <geom name="wall_s" type="box" size="5 0.05 0.5" pos="0 -5 0.5" rgba="0.5 0.5 0.5 1"/>
        <geom name="wall_e" type="box" size="0.05 5 0.5" pos="5 0 0.5" rgba="0.5 0.5 0.5 1"/>
        <geom name="wall_w" type="box" size="0.05 5 0.5" pos="-5 0 0.5" rgba="0.5 0.5 0.5 1"/>

        <!-- 3. 터틀봇 충전 스테이션 [2, 4] -->
        <body name="charging_station" pos="-4 -4 0.01">
            <geom name="station_base" type="box" size="0.3 0.3 0.01" rgba="0 1 0 0.5"/>
            <site name="docking_port" pos="0 0 0.1" size="0.05"/>
        </body>

        <!-- 4. 장애물 2개 (상자 및 팔레트 모사) [3] -->
        <geom name="obstacle_1" type="box" size="0.4 0.4 0.4" pos="2 2 0.4" rgba="0.7 0.3 0.3 1"/>
        <geom name="obstacle_2" type="box" size="0.3 0.6 0.3" pos="-1 3 0.3" rgba="0.3 0.3 0.7 1"/>

        <!-- 5. 터틀봇3 로봇 본체 -->
        <body name="base_link" pos="0 0 0.05">
            <freejoint name="root"/>
            <geom name="base_geom" type="cylinder" size="0.15 0.03" rgba="0.2 0.2 0.2 1"/>
            
            <body name="wheel_left" pos="0 0.11 0" quat="0.707 0.707 0 0">
                <joint name="drive_left" type="hinge" axis="0 0 1"/>
                <geom name="wheel_left_geom" type="cylinder" size="0.033 0.01" rgba="0.1 0.1 0.1 1"/>
            </body>
            <body name="wheel_right" pos="0 -0.11 0" quat="0.707 0.707 0 0">
                <joint name="drive_right" type="hinge" axis="0 0 1"/>
                <geom name="wheel_right_geom" type="cylinder" size="0.033 0.01" rgba="0.1 0.1 0.1 1"/>
            </body>

            <body name="sensor_tower" pos="0 0 0.1">
                <site name="lidar_site" pos="0 0 0.05"/>
                <camera name="patrol_camera" pos="0.05 0 0.02" fovy="60" quat="0.5 -0.5 0.5 -0.5"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <velocity name="motor_left" joint="drive_left" kv="10"/>
        <velocity name="motor_right" joint="drive_right" kv="10"/>
    </actuator>

    <sensor>
        <rangefinder name="lidar" site="lidar_site"/>
    </sensor>
</mujoco>