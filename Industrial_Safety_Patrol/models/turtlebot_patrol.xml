<mujoco model="turtlebot_patrol">
    <compiler angle="degree" coordinate="local" inertiafromgeom="false"/>
    <option integrator="implicitfast" timestep="0.005" gravity="0 0 -9.81"/> <!-- 200Hz 물리, 제어는 100Hz -->

    <default>
        <joint damping="0.01" armature="0.001"/>
        <geom friction="1.0 0.005 0.0001" condim="3" contype="1" conaffinity="1"/>
    </default>

    <worldbody>
        <!-- ================================================================
             <Quaternion (쿼터니언)>
             - 회전축 = (ax, ay, az), 회전각도 = θ
             - w = cos(θ/2)
             - x = ax × sin(θ/2)
             - y = ay × sin(θ/2)
             - z = az × sin(θ/2)  
             ================================================================ -->
        <!-- ================================================================
             <TurtleBot3 Burger 로봇 본체>
             (ROBOTIS 공식 스펙 기반 현실 크기)
             크기: 138mm(L) x 178mm(W) x 192mm(H)
             무게: ~1.0 kg
             바퀴 반경: 33mm, 트랙 폭: 160mm
             ================================================================ -->
        <body name="base_link" pos="-4 -4 0.043" quat="0.707107 0 0 0.707107">
            <freejoint name="root"/>
            <inertial pos="-0.02 0 0.005" mass="0.7"
                      diaginertia="0.0012 0.0012 0.0018"/>
            <!-- 하단 플레이트 (1층: 모터+배터리) -->
            <geom name="base_plate_lower" type="box"
                  size="0.069 0.089 0.0025" pos="0 0 0"
                  rgba="0.15 0.15 0.15 1"/>
            <!-- 상단 플레이트 (2층: SBC) -->
            <geom name="base_plate_upper" type="box"
                  size="0.069 0.089 0.0025" pos="0 0 0.05"
                  rgba="0.15 0.15 0.15 1"/>
            <!-- 4개 지지 기둥 -->
            <geom name="pillar_fl" type="cylinder" size="0.006 0.025"
                  pos="0.05 0.065 0.025" rgba="0.7 0.7 0.7 1"
                  contype="0" conaffinity="0"/>
            <geom name="pillar_fr" type="cylinder" size="0.006 0.025"
                  pos="0.05 -0.065 0.025" rgba="0.7 0.7 0.7 1"
                  contype="0" conaffinity="0"/>
            <geom name="pillar_rl" type="cylinder" size="0.006 0.025"
                  pos="-0.05 0.065 0.025" rgba="0.7 0.7 0.7 1"
                  contype="0" conaffinity="0"/>
            <geom name="pillar_rr" type="cylinder" size="0.006 0.025"
                  pos="-0.05 -0.065 0.025" rgba="0.7 0.7 0.7 1"
                  contype="0" conaffinity="0"/>

            <!-- 왼쪽 구동 바퀴 (DYNAMIXEL XL430-W250-T) -->
            <body name="wheel_left" pos="0 0.08 0" quat="0.707107 0.707107 0 0">
                <joint name="drive_left" type="hinge" axis="0 0 -1"
                       damping="0.005" frictionloss="0.01"/>
                <inertial pos="0 0 0" mass="0.05"
                          diaginertia="0.00003 0.00003 0.00005"/>
                <geom name="wheel_left_geom" type="cylinder"
                      size="0.033 0.0125" rgba="0.05 0.05 0.05 1"
                      friction="1.5 0.005 0.0001"/>
            </body>

            <!-- 오른쪽 구동 바퀴 -->
            <body name="wheel_right" pos="0 -0.08 0" quat="0.707107 0.707107 0 0">
                <joint name="drive_right" type="hinge" axis="0 0 -1"
                       damping="0.005" frictionloss="0.01"/>
                <inertial pos="0 0 0" mass="0.05"
                          diaginertia="0.00003 0.00003 0.00005"/>
                <geom name="wheel_right_geom" type="cylinder"
                      size="0.033 0.0125" rgba="0.05 0.05 0.05 1"
                      friction="1.5 0.005 0.0001"/>
            </body>

            <!-- 후방 볼 캐스터 (3점 지지) -->
            <body name="caster_ball" pos="-0.06 0 -0.023">
                <geom name="caster_geom" type="sphere" size="0.01"
                      rgba="0.6 0.6 0.6 1" friction="0.1 0.005 0.0001"
                      mass="0.02"/>
            </body>

            <!-- 센서 타워 -->
            <body name="sensor_tower" pos="0 0 0.055">
                <!-- LiDAR 마운트 기둥 -->
                <geom name="tower_post" type="cylinder"
                      size="0.01 0.0535" pos="0 0 0.0535"
                      rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0" mass="0.05"/>

                <!-- LDS-01 LiDAR 센서 (360빔, 1° 간격 → 360°) -->
                <body name="lidar_body" pos="0 0 0.107">
                    <inertial pos="0 0 0" mass="0.1"
                              diaginertia="0.00005 0.00005 0.00003"/>
                    <geom name="lidar_geom" type="cylinder"
                          size="0.035 0.018" rgba="0.1 0.1 0.1 1"
                          contype="0" conaffinity="0"/>
                    <replicate count="360" sep="-" offset="0 0 0" euler="0 0 1">
                        <site name="lidar_site" pos="0.07 0 0" euler="0 90 0" size="0.005"/>
                    </replicate>
                </body>

                <!-- RGB-D 카메라 (전방): PPE, 화재, 쓰러짐 탐지 -->
                <body name="camera_body" pos="0.069 0 0.06">
                    <geom name="camera_geom" type="box"
                          size="0.015 0.04 0.012" rgba="0.2 0.2 0.2 1"
                          contype="0" conaffinity="0" mass="0.03"/>
                    <camera name="patrol_camera" pos="0 0 0"
                            fovy="58" quat="0.5 0.5 -0.5 0.5"/>
                    <site name="camera_site" pos="0 0 0" size="0.005"/>
                </body>

                <!-- IMU 센서 위치 -->
                <site name="imu_site" pos="0 0 0.01" size="0.005"/>
            </body>
        </body>
    </worldbody>

    <!-- ======== 액추에이터: DYNAMIXEL XL430-W250-T ======== -->
    <actuator>
        <velocity name="motor_left" joint="drive_left"
                  kv="5" forcerange="-1.4 1.4"
                  ctrlrange="-6.67 6.67"/>
        <velocity name="motor_right" joint="drive_right"
                  kv="5" forcerange="-1.4 1.4"
                  ctrlrange="-6.67 6.67"/>
    </actuator>

    <!-- ======== 센서 정의 ======== -->
    <sensor>
        <!-- ================================================================
             <LDS-01 LiDAR 참고>
             360° × 360빔 (1° 해상도), 5~10Hz
             거리: 0.12~3.5m
             ================================================================ -->
        <!-- 360도 스캔을 위한 360개 빔 개별 선언 -->
        <rangefinder name="lidar" site="lidar_site" cutoff="3.5"/>
        <!-- IMU: 3축 가속도계 + 3축 자이로스코프 -->
        <accelerometer name="imu_accel" site="imu_site"/>
        <gyro name="imu_gyro" site="imu_site"/>
        <!-- 바퀴 인코더: 바퀴의 회전량과 회전 속도를 측정 -->
        <jointvel name="encoder_left" joint="drive_left"/>
        <jointvel name="encoder_right" joint="drive_right"/>
        <jointpos name="encoder_pos_left" joint="drive_left"/>
        <jointpos name="encoder_pos_right" joint="drive_right"/>
    </sensor>
</mujoco>